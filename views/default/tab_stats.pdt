<?php /** @var View $this **/ ?>

<h6 class="form-section-header first"><?php $this->_('Centovacast.tab_stats.info_title'); ?></h6>
<div class="pad">
    <table class="table">
        <thead>
            <tr>
                <th style="width: 50%;"><?php $this->_('Centovacast.tab_stats.info_heading.field'); ?></th>
                <th><?php $this->_('Centovacast.tab_stats.info_heading.value'); ?></th>
            </tr>
        </thead>
        <tbody>
            <?php
            $keys = [
                'username',
                'hostname',
                'ipaddress',
                'port',
                'maxclients',
                'samplerate',
                'maxbitrate',
                'adminpassword',
                'sourcepassword',
            ];
            $i = 1;
            foreach ($account_info as $key => $value) {
                if (in_array($key, $keys)) { ?>
            <tr>
                <td><?php $this->_('Centovacast.tab_stats.info.' . $key); ?></td>
                <td><?php echo isset($value) ? $this->Html->safe($value) : null; ?></td>
            </tr>
                    <?php }

                $i++;
            }
            ?>
        </tbody>
    </table>
</div>

<h6 class="form-section-header mt-4"><?php $this->_('Centovacast.tab_stats.bandwidth_title'); ?></h6>
<div class="pad">
    <table class="table">
        <thead>
            <tr>
                <th style="width: 50%;"><?php $this->_('Centovacast.tab_stats.bandwidth_heading.used'); ?></th>
                <th><?php $this->_('Centovacast.tab_stats.bandwidth_heading.limit'); ?></th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    <?php
                    $usage = isset($account_info->cachedtransfer) ? $account_info->cachedtransfer : 0;
                    $this->_('Centovacast.tab_stats.bandwidth_value', false, round($usage, 2));
                    ?>
                </td>
                <td>
                    <?php
                    $limit = isset($account_info->transferlimit) ? $account_info->transferlimit : 0;
                    $this->_(
                        $account_info->transferlimit == 'unlimited' || $limit == 0
                            ? 'Centovacast.tab_stats.bandwidth_unlimited'
                            : 'Centovacast.tab_stats.bandwidth_value',
                        false,
                        round($limit, 2),
                    );
                    ?>
                </td>
            </tr>
        </tbody>
    </table>
</div>

<h6 class="form-section-header mt-4"><?php $this->_('Centovacast.tab_stats.disk_title'); ?></h6>
<div class="pad">
    <table class="table">
        <thead>
            <tr>
                <th style="width: 50%;"><?php $this->_('Centovacast.tab_stats.disk_heading.used'); ?></th>
                <th><?php $this->_('Centovacast.tab_stats.disk_heading.limit'); ?></th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>
                    <?php
                    $usage = isset($account_info->cacheddiskusage) ? $account_info->cacheddiskusage : 0;
                    $this->_('Centovacast.tab_stats.disk_value', false, round($usage, 2));
                    ?>
                </td>
                <td>
                    <?php
                    $limit = isset($account_info->diskquota) ? $account_info->diskquota : 0;
                    $this->_(
                        $account_info->diskquota == 'unlimited' || $limit == 0
                            ? 'Centovacast.tab_stats.disk_unlimited'
                            : 'Centovacast.tab_stats.disk_value',
                        false,
                        round($limit, 2),
                    );
                    ?>
                </td>
            </tr>
        </tbody>
    </table>
</div>